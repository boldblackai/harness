{
  "name": "@boldblackai/harness",
  "version": "1.9.1",
  "description": "Portable environment for running coding agents in a container",
  "bin": {
    "harness": "bin/harness.js"
  },
  "files": ["bin/"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boldblackai/harness.git"
  },
  "packageManager": "pnpm@11.9.0",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && cp -r src/seccomp-profiles bin/seccomp-profiles",
    "prepare": "tsc",
    "lint": "pnpm lint:ts && pnpm lint:md && pnpm lint:sh && pnpm lint:docker && pnpm lint:actions",
    "lint:ts": "biome check .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:sh": "shellcheck setup-env.sh entrypoint.sh entrypoint-opencode.sh entrypoint-hermes.sh",
    "lint:docker": "hadolint Dockerfile Dockerfile.opencode Dockerfile.hermes",
    "lint:actions": "actionlint",
    "format": "biome format --write .",
    "test:e2e:cli": "node --test tests/e2e/*.test.mjs",
    "test:e2e": "node --test tests/e2e/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**\" --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80 tests/e2e/*.test.mjs"
  },
  "dependencies": {
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.6.0",
    "markdownlint-cli2": "0.17.2",
    "typescript": "^6.0.2"
  }
}
